# ---------------------------------------------------------------------------
# Support Context Budget Lab — environment variables
# Copy to `.env` and fill in your keys:  cp .env.example .env
# ---------------------------------------------------------------------------

# --- Required: providers ---
TAVILY_API_KEY="tvly-..."           # https://app.tavily.com
NEBIUS_API_KEY="..."                # https://tokenfactory.nebius.com

# --- Model (matches the starter agent) ---
NEBIUS_MODEL="moonshotai/Kimi-K2.6"

# --- Estimated pricing (USD per 1M tokens). Used for "estimated cost" only. ---
# Adjust to the current Nebius price sheet for your model.
INPUT_COST_PER_1M="0.60"
OUTPUT_COST_PER_1M="2.40"

# --- Pruning defaults (overridable per session from the UI) ---
PRUNE_EVERY="2"
RECENT_TURNS_TO_KEEP="2"

# --- Server ---
BACKEND_HOST="127.0.0.1"
BACKEND_PORT="8000"

# --- Frontend -> backend URL (Next.js) ---
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000"

# --- Optional: LangSmith tracing (bonus, off by default) ---
# LANGSMITH_TRACING="true"
# LANGSMITH_API_KEY="..."
# LANGSMITH_PROJECT="support-context-budget-lab"
